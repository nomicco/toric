{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Toric",
  "version": "0.1.0",
  "identifier": "network.toric.node",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev --workspace ui",
    "beforeBuildCommand": "npm run build --workspace ui"
  },
  "app": {
    "windows": [
      {
        "title": "Toric",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "holochain-bin": "holochain",
      "holochain-nix-closure.tar.gz": "holochain-nix-closure.tar.gz",
      "../api": "api",
      "../scripts": "scripts",
      "../workdir/toric.happ": "toric.happ"
    },
    "linux": {
      "deb": {
        "depends": ["patchelf"]
      }
    }
  }
}
