  display: flex;
  gap: 8px;
  align-items: center;
}

/* ─── Status Panel ──────────────────────────────── */
.status-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 0;
  border-bottom: 1px solid var(--border);
}
.stat-card {
  padding: 20px 24px;
  border-right: 1px solid var(--border);
}
.stat-card:last-child { border-right: none; }
.stat-label { font-size: 9px; color: var(--text3); letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 8px; }
.stat-value { font-size: 28px; font-weight: 300; color: var(--text); line-height: 1; }
.stat-value.accent { color: var(--accent); }
.stat-value.warn   { color: var(--warn); }
.stat-sub { font-size: 10px; color: var(--text3); margin-top: 4px; }
.stat-sub.up   { color: var(--accent); }
.stat-sub.down { color: var(--warn); }

.section-head {
  padding: 16px 24px 8px;
  font-size: 9px;
  color: var(--text3);
  letter-spacing: 0.15em;
  text-transform: uppercase;
  border-bottom: 1px solid var(--border);
}

.manifest-row {
  display: grid;
  grid-template-columns: 1fr 80px 80px;
  gap: 12px;
  align-items: center;
  padding: 10px 24px;
  border-bottom: 1px solid var(--border);
  font-size: 11px;
  cursor: pointer;
  transition: background 0.1s;
}
.manifest-row:hover { background: var(--bg2); }
.mr-hash { color: var(--text2); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.mr-arch { color: var(--text3); }
.mr-score { text-align: right; }
.mr-score.pass { color: var(--accent); }
.mr-score.fail { color: var(--warn); }

.phase-badge {
  display: inline-flex;
  align-items: center;
  gap: 5px;
  font-size: 10px;
  padding: 3px 8px;
  border: 1px solid var(--border2);
  color: var(--text2);
  margin-top: 8px;
}
.phase-badge.genesis  { border-color: var(--amber); color: var(--amber); }
.phase-badge.governed { border-color: var(--accent); color: var(--accent); }

.fib-progress {
  margin: 16px 24px;
}
.fib-label {
  display: flex;
  justify-content: space-between;
  font-size: 10px;
  color: var(--text3);
  margin-bottom: 6px;
}
.fib-bar { height: 2px; background: var(--bg3); }
.fib-fill { height: 100%; background: var(--accent); transition: width 0.6s ease; }

/* ─── Network Panel ─────────────────────────────── */
.phi-table { padding: 0; }
.phi-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  padding: 10px 24px;
  border-bottom: 1px solid var(--border);
  font-size: 11px;
}
.phi-name { color: var(--text2); }
.phi-val  { color: var(--accent); text-align: right; }

/* ─── Empty / Loading states ────────────────────── */
.empty {
  padding: 32px 24px;
  color: var(--text3);
  font-size: 12px;
}
.empty::before { content: '> '; color: var(--text3); }

.loading {
  display: inline-block;
  color: var(--text3);
  font-size: 12px;
}
.loading::after {
  content: '...';
  animation: dots 1.2s steps(4, end) infinite;
}
@keyframes dots {
  0%   { content: ''; }
  25%  { content: '.'; }
  50%  { content: '..'; }
  75%  { content: '...'; }
}

/* ─── Utilities ─────────────────────────────────── */
.hash {
  font-size: 11px;
  color: var(--text3);
  cursor: pointer;
  transition: color 0.1s;
}
.hash:hover { color: var(--accent); }

.tag {
  display: inline-block;
  font-size: 9px;
  padding: 2px 6px;
  border: 1px solid var(--border2);
  color: var(--text3);
  letter-spacing: 0.06em;
  margin: 1px;
}
.tag.pass { border-color: rgba(57,232,160,0.3); color: var(--accent); }
.tag.fail { border-color: rgba(232,87,87,0.3);  color: var(--warn); }
</style>
</head>
<body>
<div class="shell">

  <!-- Topbar -->
  <header class="topbar">
    <div class="topbar-left">
      <span class="topbar-logo">TORIC</span>
      <span class="topbar-sep">/</span>
      <span id="tb-net">proof of integrity network</span>
    </div>
    <div class="topbar-right">
      <span><span class="status-dot" id="conn-dot"></span><span id="conn-status">connecting</span></span>
      <span id="tb-time"></span>
    </div>
  </header>

  <!-- Sidebar -->
  <aside class="sidebar">
    <nav class="nav" id="nav">
      <div class="nav-section">observe</div>
      <div class="nav-item active" data-panel="monitor">
        <i class="icon">⬡</i> Monitor
      </div>
      <div class="nav-section">query</div>
      <div class="nav-item" data-panel="query">
        <i class="icon">◈</i> Query
      </div>
      <div class="nav-section">node</div>
      <div class="nav-item" data-panel="status">
        <i class="icon">◉</i> Status
      </div>
      <div class="nav-item" data-panel="network">
        <i class="icon">⬡</i> Network
      </div>
      <div class="nav-section">discover</div>
      <div class="nav-item" data-panel="browse">
        <i class="icon">◎</i> Browse
      </div>
      <div class="nav-section">develop</div>
      <div class="nav-item" data-panel="lab">
        <i class="icon">◌</i> Lab
      </div>
    </nav>
    <div class="sidebar-foot">
      <div style="color:var(--text3);font-size:9px;letter-spacing:0.1em;text-transform:uppercase">agent</div>
      <div class="agent-key" id="agent-key" title="click to copy">—</div>
    </div>
  </aside>

  <!-- Main -->
  <main class="main">

    <!-- Monitor Panel -->
    <div class="panel active" id="panel-monitor">
      <div class="panel-header">
        <div class="panel-title">monitor</div>
        <div class="panel-sub">live network event stream</div>
      </div>
      <div class="panel-body">
        <div class="event-stream" id="event-stream">
          <div class="stream-empty">awaiting events</div>
        </div>
      </div>
    </div>

    <!-- Query Panel -->
    <div class="panel" id="panel-query">
      <div class="panel-header">
        <div class="panel-title">query</div>
        <div class="panel-sub">manifest hash · content hash · agent pubkey</div>
      </div>
      <div class="search-bar">
        <span class="search-prompt">&gt;</span>
        <input class="search-input" id="search-input" type="text"
          placeholder="hCkk... or sha256:... or uhCAk..."
          autocomplete="off" spellcheck="false">
      </div>
      <div class="panel-body">
        <div class="query-result" id="query-result">
          <div class="empty">enter a hash to query</div>
        </div>
      </div>
    </div>

    <!-- Status Panel -->
    <div class="panel" id="panel-status">
      <div class="panel-header">
        <div class="panel-title">status</div>
        <div class="panel-sub">this node</div>
      </div>
      <div class="panel-body" id="status-body">
        <div class="empty loading">loading</div>
      </div>
    </div>

    <!-- Network Panel -->
    <div class="panel" id="panel-network">
      <div class="panel-header">
        <div class="panel-title">network</div>
        <div class="panel-sub">φ-derived parameters — none chosen, all forced</div>
      </div>
      <div class="panel-body" id="network-body">
        <div class="empty loading">loading</div>
      </div>
    </div>

    <!-- Lab Panel -->
    <div class="panel" id="panel-lab">
      <div class="panel-header">
        <div class="panel-title">lab</div>
        <div class="panel-sub">register manifests · build provenance chains · observe trust score dimensions</div>
      </div>
      <div class="panel-body" id="lab-body">
        <div id="lab-chain" style="padding:20px 24px;border-bottom:1px solid var(--border)">
          <div style="font-size:9px;color:var(--text3);letter-spacing:0.15em;text-transform:uppercase;margin-bottom:12px">provenance chain</div>
          <div id="lab-chain-nodes" style="display:flex;flex-direction:column;gap:8px"></div>
          <div style="margin-top:12px;display:flex;gap:8px">
            <button id="lab-btn-base" onclick="Panels.lab.registerBase()" style="background:var(--bg3);border:1px solid var(--border2);color:var(--text);font-family:var(--mono);font-size:11px;padding:6px 14px;cursor:pointer;letter-spacing:0.06em">+ base model</button>
            <button id="lab-btn-deriv" onclick="Panels.lab.registerDerivative()" style="background:var(--bg3);border:1px solid var(--border2);color:var(--text2);font-family:var(--mono);font-size:11px;padding:6px 14px;cursor:pointer;letter-spacing:0.06em" disabled>+ derivative</button>
            <button id="lab-btn-clear" onclick="Panels.lab.clear()" style="background:transparent;border:1px solid var(--border);color:var(--text3);font-family:var(--mono);font-size:11px;padding:6px 14px;cursor:pointer;letter-spacing:0.06em">clear</button>
          </div>
        </div>
        <div id="lab-scores" style="padding:20px 24px"></div>
        <div id="lab-queue" style="border-top:1px solid var(--border)"></div>
        <div id="lab-log" style="padding:0 24px 20px;font-size:11px;color:var(--text3)"></div>
      </div>
    </div>

    <!-- Browse Panel -->
    <div class="panel" id="panel-browse">
      <div class="panel-header">
        <div class="panel-title">browse</div>
        <div class="panel-sub">all registered models — ranked by trust score</div>
      </div>
      <div class="panel-body" id="browse-body">
        <div class="empty loading">loading</div>
      </div>
    </div>

  </main>

  <!-- Statusbar -->
  <footer class="statusbar">
    <div class="statusbar-left">
      <div class="sb-item">
        <span class="sb-label">attestations</span>
        <span class="sb-value accent" id="sb-att">—</span>
      </div>
      <div class="sb-item">
        <span class="sb-label">threshold</span>
        <span class="sb-value" id="sb-threshold">—</span>
      </div>
      <div class="sb-item">
        <span class="sb-label">supply</span>
        <span class="sb-value" id="sb-supply">—</span>
      </div>
      <div class="sb-item">
        <span class="sb-label">phase</span>
        <span class="sb-value" id="sb-phase">—</span>
      </div>
    </div>
    <div class="statusbar-right">
      <div class="sb-item">
        <span class="sb-label">events</span>
        <span class="sb-value" id="sb-events">0</span>
      </div>
    </div>
  </footer>

</div>

<script>
// ─────────────────────────────────────────────────
// Configuration
// Panels register themselves — adding a new panel
// requires only: add nav-item, add panel div, add
// to PANELS registry, implement render function.
// ─────────────────────────────────────────────────

const params = new URLSearchParams(window.location.search);
const apiPort = params.get('api') || '3000';
const API = `http://localhost:${apiPort}/v1`;
const SIGNALS_URL = `http://localhost:${apiPort}/signals`;

// ─────────────────────────────────────────────────
// State
// ─────────────────────────────────────────────────

const State = {
  agent: null,
  connected: false,
  networkState: null,
  reputation: null,
  myManifests: [],
  eventCount: 0,
};

// ─────────────────────────────────────────────────
// API
// ─────────────────────────────────────────────────

const Api = {
  async get(path) {
    const res = await fetch(`${API}${path}`);
    if (!res.ok) throw new Error(`${res.status} ${path}`);
    return res.json();
  },
  async post(path, body) {
    const res = await fetch(`${API}${path}`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    if (!res.ok) throw new Error(`${res.status} ${path}`);
    return res.json();
  },
};

// ─────────────────────────────────────────────────
// Router
// ─────────────────────────────────────────────────

const Router = {
  current: 'monitor',
  navigate(panelId) {
    document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    const panel = document.getElementById(`panel-${panelId}`);
    const navItem = document.querySelector(`[data-panel="${panelId}"]`);
    if (panel) panel.classList.add('active');
    if (navItem) navItem.classList.add('active');
    this.current = panelId;
    Panels[panelId]?.onActivate?.();
  },
};

document.getElementById('nav').addEventListener('click', e => {
  const item = e.target.closest('.nav-item');
  if (item?.dataset.panel) Router.navigate(item.dataset.panel);
});

// ─────────────────────────────────────────────────
// Utilities
// ─────────────────────────────────────────────────

const fmt = {
  hash: h => h ? `${h.slice(0,8)}…${h.slice(-6)}` : '—',
  score: s => typeof s === 'number' ? s.toFixed(4) : '—',
  delta: d => {
    if (typeof d !== 'number') return '';
    return d >= 0 ? `↑${d.toFixed(3)}` : `↓${Math.abs(d).toFixed(3)}`;
  },
  time: () => new Date().toISOString().slice(11, 19),
  arch: a => a || '—',
  params: n => {
    if (!n) return '—';
    if (n >= 1e12) return (n/1e12).toFixed(1)+'T';
    if (n >= 1e9)  return (n/1e9).toFixed(1)+'B';
    if (n >= 1e6)  return (n/1e6).toFixed(1)+'M';
    return n.toString();
  },
};

function copyText(text) {
  navigator.clipboard?.writeText(text).then(() => {
    const el = document.querySelector('.agent-key');
    if (el) {
      const orig = el.textContent;
      el.textContent = 'copied';
      el.style.color = 'var(--accent)';
      setTimeout(() => {
        el.textContent = orig;
        el.style.color = '';
      }, 300);
    }
  });
}

function passes(score) { return typeof score === 'number' && score >= 0.618; }

// ─────────────────────────────────────────────────
// Panels registry
// To add a new panel: implement { onActivate, render }
// ─────────────────────────────────────────────────

const Panels = {};

// ─── Monitor Panel ───────────────────────────────

let maxEvents = 200;

Panels.monitor = {
  onActivate() {},
  addEvent(type, hash, raw) {
    State.eventCount++;
    document.getElementById('sb-events').textContent = State.eventCount;

    const stream = document.getElementById('event-stream');
    const empty = stream.querySelector('.stream-empty');
    if (empty) empty.remove();

    const typeClass = {
      'ValidationRequested': 'validation',
      'QuorumReached':        'quorum',
      'AttestationCreated':   'attestation',
      'WarrantCreated':        'warrant',
      'ManifestCreated':       'manifest',
    }[type] || 'manifest';

    const typeLabel = {
      'ValidationRequested': 'VALIDATION.REQ',
      'QuorumReached':        'QUORUM.REACHED',
      'AttestationCreated':   'ATTESTATION',
      'WarrantCreated':        'WARRANT',
      'ManifestCreated':       'MANIFEST',
    }[type] || type;

    const row = document.createElement('div');
    row.className = 'event-row';
    row.innerHTML = `
      <span class="ev-time">${fmt.time()}</span>
      <span class="ev-type ${typeClass}">${typeLabel}</span>
      <span class="ev-hash">${hash || '—'}</span>
    `;

    stream.prepend(row);

    // Prune old events
    const rows = stream.querySelectorAll('.event-row');
    if (rows.length > maxEvents) rows[rows.length - 1].remove();
  },
};

// ─── Query Panel ─────────────────────────────────

Panels.query = {
  onActivate() {
    document.getElementById('search-input').focus();
  },
  async search(val) {
    const container = document.getElementById('query-result');
    container.innerHTML = '<div class="empty loading">querying</div>';

    try {
      if (val.startsWith('hCkk') || val.startsWith('hC')) {
        await this.renderManifest(container, val);
      } else if (val.startsWith('uhCAk') || val.startsWith('uhC')) {
        await this.renderAgent(container, val);
      } else if (val.startsWith('sha256:') || val.match(/^[a-f0-9]{64}$/)) {
        await this.renderConvergence(container, val);
      } else {
        container.innerHTML = '<div class="empty">unrecognized format — enter manifest hash (hCkk...), agent pubkey (uhCAk...), or content hash (sha256:...)</div>';
      }
    } catch(e) {
      container.innerHTML = `<div class="empty">error: ${e.message}</div>`;
    }
  },

  async renderManifest(container, hash) {
    const entry_preview = await Api.get(`/manifest/${hash}`).catch(() => null);
    const contentHash = entry_preview?.entry?.content_hash;

    const [manifest, attestations, warrants, trustScore, upstreams, derivatives, convergenceHashes] = await Promise.all([
      Api.get(`/manifest/${hash}`),
      Api.get(`/manifest/${hash}/attestations`).catch(() => []),
      Api.get(`/manifest/${hash}/warrants`).catch(() => []),
      Api.get(`/manifest/${hash}/trust-score`).catch(() => null),
      Api.get(`/manifest/${hash}/upstreams`).catch(() => []),
      Api.get(`/manifest/${hash}/derivatives`).catch(() => []),
      contentHash ? Api.get(`/content/${encodeURIComponent(contentHash)}/manifests`).catch(() => []) : Promise.resolve([]),
    ]);

    const entry = manifest.entry || {};
    const score = trustScore?.score ?? 0;
    const pct = (score * 100).toFixed(1);
    const scoreClass = passes(score) ? 'accent' : 'warn';
    const warrantHtml = warrants.length > 0
      ? `<div class="warrant-banner">⚠ ${warrants.length} active warrant${warrants.length > 1 ? 's' : ''}</div>`
      : '';

    const attRows = (attestations || []).map(a => {
      const p = a.entry?.passed !== false;
      const sc = a.entry?.score != null ? Number(a.entry.score).toFixed(3) : '—';
      return `<div class="att-row">
        <div class="att-dot ${p ? 'pass' : 'fail'}"></div>
        <div class="att-agent hash" onclick="copyText('${a.author}')" title="${a.author}">${fmt.hash(a.author)}</div>
        <div class="att-score">${sc}</div>
        <div class="att-verdict ${p ? 'pass' : 'fail'}">${p ? 'pass' : 'fail'}</div>
      </div>`;
    }).join('');

    const upstreamHtml = upstreams.length > 0
      ? upstreams.map(h => `<span class="lineage-hash" onclick="Panels.query.goHash('${h}')">${fmt.hash(h)}</span>`).join('')
      : '<span style="color:var(--text3);font-size:11px">none</span>';

    const derivHtml = derivatives.length > 0
      ? derivatives.map(h => `<span class="lineage-hash" onclick="Panels.query.goHash('${h}')">${fmt.hash(h)}</span>`).join('')
      : '<span style="color:var(--text3);font-size:11px">none</span>';

    container.innerHTML = `
      ${warrantHtml}
      <div class="query-result">
        <div class="result-block">
          <div class="rb-header">
            <span class="rb-title">trust score</span>
            <span class="rb-value ${scoreClass}">${fmt.score(score)}</span>
          </div>
          <div class="score-bar">
            <div class="score-fill ${passes(score) ? '' : 'warn'}" style="width:${pct}%"></div>
            <div class="score-threshold"></div>
          </div>
          <div class="kv-grid">
            <div class="kv-item"><div class="kv-key">hash</div><div class="kv-val hash" onclick="copyText('${hash}')" title="${hash}">${fmt.hash(hash)}</div></div>
            <div class="kv-item"><div class="kv-key">architecture</div><div class="kv-val">${fmt.arch(entry.architecture)}</div></div>
            <div class="kv-item"><div class="kv-key">parameters</div><div class="kv-val">${fmt.params(entry.parameter_count)}</div></div>
            <div class="kv-item"><div class="kv-key">version</div><div class="kv-val">${entry.version || '—'}</div></div>
            <div class="kv-item"><div class="kv-key">source</div><div class="kv-val">${entry.connector_source || '—'}</div></div>
            <div class="kv-item"><div class="kv-key">attestations</div><div class="kv-val ${attestations.length > 0 ? 'accent' : ''}">${attestations.length}</div></div>
            <div class="kv-item" style="grid-column:1/-1"><div class="kv-key">description</div><div class="kv-val" style="white-space:normal">${entry.description || '—'}</div></div>
          </div>
        </div>

        ${attestations.length > 0 ? `
        <div class="result-block">
          <div class="rb-header"><span class="rb-title">attestations</span></div>
          <div class="attestation-list">${attRows}</div>
        </div>` : ''}

        ${convergenceHashes.length > 1 ? `
        <div class="result-block">
          <div class="rb-header">
            <span class="rb-title">convergence</span>
            <span class="rb-value accent">${convergenceHashes.length}</span>
          </div>
          <div class="lineage-section">
            <div class="lineage-label">independent registrations of same weights</div>
            <div>${convergenceHashes
              .filter(h => h !== hash)
              .map(h => `<span class="lineage-hash" onclick="Panels.query.goHash('${h}')">${fmt.hash(h)}</span>`)
              .join('')}
            </div>
          </div>
        </div>` : ''}

        <div class="result-block">
          <div class="rb-header"><span class="rb-title">lineage</span></div>
          <div class="lineage-section">
            <div class="lineage-label">upstream</div>
            <div>${upstreamHtml}</div>
          </div>
          <div class="lineage-section" style="border-top:1px solid var(--border)">
            <div class="lineage-label">derivatives</div>
            <div>${derivHtml}</div>
          </div>
        </div>
      </div>
    `;
  },

  async renderAgent(container, pubkey) {
    const [rep, manifests] = await Promise.all([
      Api.get(`/agent/${pubkey}/reputation`).catch(() => ({})),
      Api.get(`/agent/${pubkey}/manifests`).catch(() => []),
    ]);

    const deltaClass = rep.score_delta >= 0 ? 'up' : 'down';
    const manifestRows = manifests.map(m => {
      const e = m.entry || {};
      return `<div class="manifest-row" onclick="Panels.query.goHash('${m.hash}')">
        <div class="mr-hash hash">${fmt.hash(m.hash)} <span style="color:var(--text3)">${e.architecture || ''}</span></div>
        <div class="mr-arch">${fmt.params(e.parameter_count)}</div>
        <div class="mr-score">—</div>
      </div>`;
    }).join('');

    container.innerHTML = `
      <div class="query-result">
        <div class="result-block">
          <div class="rb-header">
            <span class="rb-title">agent</span>
            <span class="rb-value ${passes(rep.score) ? 'accent' : 'warn'}">${fmt.score(rep.score)}</span>
          </div>
          <div class="kv-grid">
            <div class="kv-item"><div class="kv-key">pubkey</div><div class="kv-val hash" onclick="copyText('${pubkey}')">${fmt.hash(pubkey)}</div></div>
            <div class="kv-item"><div class="kv-key">trajectory</div><div class="kv-val ${deltaClass}">${fmt.delta(rep.score_delta)}</div></div>
            <div class="kv-item"><div class="kv-key">attestations</div><div class="kv-val">${rep.attestation_count ?? 0}</div></div>
            <div class="kv-item"><div class="kv-key">warrants</div><div class="kv-val ${rep.warrant_count > 0 ? 'warn' : ''}">${rep.warrant_count ?? 0}</div></div>
          </div>
        </div>
        ${manifests.length > 0 ? `
        <div class="result-block">
