      let dimScores = { hash_score: null, provenance_score: null, static_score: null, probe_score: null };
      if (attestations.length > 0) {
        const latest = attestations[attestations.length - 1];
        const e = latest.entry || {};
        dimScores = {
          hash_score:       e.hash_score       ?? null,
          provenance_score: e.provenance_score ?? null,
          static_score:     e.static_score     ?? null,
          probe_score:      e.probe_score      ?? null,
