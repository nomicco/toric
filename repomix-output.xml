            </div>
            <div style="font-size:11px;color:${color};text-align:right">${v}</div>
          </div>`;
      };

      block.innerHTML = `
        <div style="display:flex;align-items:center;justify-content:space-between;padding:10px 16px;border-bottom:1px solid var(--border)">
          <span style="font-size:11px;color:var(--text2);letter-spacing:0.08em">${label}</span>
