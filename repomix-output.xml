      await Api.post('/debug/attest/' + requestHash, {});
      this.log(`attestation submitted for ${fmt.hash(requestHash)}`, true);
    } catch(e) {
      this.log(`validation error: ${e.message}`);
    }
  },
};

Panels.browse = {
  loaded: false,
  async onActivate() {
    if (!this.loaded) await this.render();
