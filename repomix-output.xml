  async registerBase() {
    const btn = document.getElementById('lab-btn-base');
    btn.textContent = 'registering...';
    btn.disabled = true;
    try {
      const contentHash = 'sha256:' + Array.from(crypto.getRandomValues(new Uint8Array(16)))
        .map(b => b.toString(16).padStart(2,'0')).join('');
      const label = `base-${this.chain.length + 1}`;
      const { hash } = await Api.post('/manifest', {
        blob: {
          blob_type: 'ai_model',
          content_hash: contentHash,
          architecture: 'llama',
          parameter_count: 7000000000,
